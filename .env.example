# Telegram
BOT_TOKEN=
# Your personal Telegram user id — receives bot/worker crash + startup notifications.
# Get it by writing /start to @userinfobot in Telegram.
ADMIN_CHAT_ID=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# Binance (optional – public endpoints work without key, but rate limits are higher with key)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET=your_binance_secret

# CoinGecko (free tier works without key, add for higher limits)
COINGECKO_API_KEY=your_coingecko_api_key

# CryptoPanic
CRYPTOPANIC_KEY=your_cryptopanic_api_key

# NewsAPI.org
NEWSAPI_KEY=your_newsapi_key

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# Worker interval in minutes (default: 5)
WORKER_INTERVAL_MINUTES=5
